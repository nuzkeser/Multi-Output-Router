<Window x:Class="MultiOutputRouter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multi-Output Audio Router" Height="520" Width="440"
        Background="#0D1117" Foreground="White" WindowStartupLocation="CenterScreen"
        Icon="app_icon.ico" FontFamily="Segoe UI">
    
    <Window.Resources>
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Padding" Value="0,0,10,0"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,5,10,5"/>
            <Setter Property="IsSnapToTickEnabled" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Virtual Multi-Output" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5" Foreground="#58A6FF"/>
        <TextBlock Text="Mirror audio perfectly across multiple devices." FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,25" Foreground="#8B949E" Grid.Row="1"/>

        <!-- Source Section -->
        <Border Grid.Row="3" Background="#161B22" CornerRadius="10" Padding="18" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2" Direction="270" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <TextBlock Text="1. Select Source Device" FontWeight="SemiBold" FontSize="14" Foreground="#C9D1D9" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Button Content="↻ Refresh" HorizontalAlignment="Right" Padding="12,4" Background="#21262D" Foreground="#C9D1D9" BorderThickness="1" BorderBrush="#30363D" Click="RefreshButton_Click" Cursor="Hand" FontSize="12" FontWeight="SemiBold">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                        </Button.Resources>
                    </Button>
                </Grid>
                <ComboBox x:Name="SourceComboBox" DisplayMemberPath="DeviceFriendlyName" Height="32" FontSize="13" Padding="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Destination Section -->
        <Border Grid.Row="4" Background="#161B22" CornerRadius="10" Padding="18" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2" Direction="270" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="2. Select Destination Devices" FontWeight="SemiBold" FontSize="14" Foreground="#C9D1D9" Margin="0,0,0,15"/>
                <ScrollViewer>
                    <StackPanel x:Name="DestinationsPanel">
                        <!-- Checkboxes will be injected here dynamically -->
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Control Section -->
        <Button x:Name="StartStopButton" Grid.Row="5" Content="Start Routing" Height="46" FontSize="16" FontWeight="Bold" 
                Background="#238636" Foreground="White" BorderThickness="0" Click="StartStopButton_Click" Cursor="Hand">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
